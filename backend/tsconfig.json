{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": false,
    "noImplicitAny": false,
    "strictPropertyInitialization": false,
    "noEmitOnError": false,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "types": ["node"],

    "resolveJsonModule": true
  },

  "include": ["src/**/*"],

  "exclude": ["node_modules"]
}