{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
"ignoreDeprecations": "6.0",
    "moduleResolution": "node",

   "types": ["node"],

    "typeRoots": [
      "./node_modules/@types"
    ],

    "resolveJsonModule": true
  },

  "include": ["src/**/*"],

  "exclude": ["node_modules"]
}